<launch>

    <let name="urdf_path" 
        value="$(find-pkg-share agv_mini_manipulator_description)/urdf/agv_mini_manipulator.urdf.xacro"/>

    <let name="gazebo_config_path" 
        value="$(find-pkg-share agv_mini_manipulator_bringup)/config/gazebo_bridge.yaml"/>

    <let name="rviz_config_path" 
        value="$(find-pkg-share agv_mini_manipulator_bringup)/rviz/agv_mini_manipulator_only_gazebo.rviz"/>

    <!-- Spawn robot_description -->
    <node pkg = "robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" 
            value="$(command 'xacro $(var urdf_path)')"/>
    </node>

    <!-- Gazebo simulation -->
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="empty.sdf -r"/>
    </include>
    <!-- Spawn robot in Gazebo -->
    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description"/>
    <!-- ROS Gazebo Bridge -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)"/>
    </node>

    <!-- Rviz -->
    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" 
          args="-d $(var rviz_config_path)"/>

</launch>