<?xml version ="1.0"?>

<robot name="ground_robot_noodle">

    <!-- base_footprint_base_link_joint -->

    <link name="base_footprint"/>

    <link name="base_link">
    <visual>
        <geometry>
        <box size="0.5 0.5 0.2"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>

        <material name="blue">
        <color rgba="0 0 1 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <box size="0.5 0.5 0.2 "/>
        </geometry>
        <origin xyz="0.0 0.0 0.1" rpy="1.5708 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_footprint_base_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
    </joint>

    <!-- base_footprint_base_link_joint -->

    <!-- base_link_lidar_front_joint -->

    <link name="lidar_front_link">
    <visual>
        <geometry>
        <cylinder radius="0.03" length="0.03"/>
        </geometry>
        <origin xyz="0.0 0.0 0.015" rpy="0 0 0"/>

        <material name="black">
        <color rgba="0 0 0 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <cylinder radius="0.03" length="0.03"/>
        </geometry>
        <origin xyz="0.0 0.0 0.015" rpy="1.5708 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_link_lidar_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_front_link"/>
        <origin xyz="0.2 0.0 0.1" rpy="0 0 0"/>
    </joint>

    <!-- base_link_lidar_front_joint -->

    <!-- base_link_lidar_back_joint -->

    <link name="lidar_back_link">
    <visual>
        <geometry>
        <cylinder radius="0.03" length="0.03"/>
        </geometry>
        <origin xyz="0.0 0.0 0.015" rpy="0 0 0"/>

        <material name="black">
        <color rgba="0 0 0 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <cylinder radius="0.03" length="0.03"/>
        </geometry>
        <origin xyz="0.0 0.0 0.015" rpy="1.5708 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_link_lidar_back_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_back_link"/>
        <origin xyz="-0.2 0.0 0.1" rpy="0 0 1.5708"/>
    </joint>

    <!-- base_link_lidar_back_joint -->

    <!-- base_link_right_wheel_joint -->

    <link name="right_wheel_link">
    <visual>
        <geometry>
        <cylinder radius="0.1" length="0.1"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>

        <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <cylinder radius="0.10" length="0.125"/>
        </geometry>
        <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_link_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0.0 0.3 -0.05" rpy="-1.5708 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- base_link_right_wheel_joint -->

    <!-- base_link_left_wheel_joint -->

    <link name="left_wheel_link">
    <visual>
        <geometry>
        <cylinder radius="0.10" length="0.1"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>

        <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <cylinder radius="0.10" length="0.125"/>
        </geometry>
        <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_link_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0.0 -0.3 -0.05" rpy="1.5708 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- base_link_left_wheel_joint -->

    <!-- base_link_front_wheel_joint -->

    <link name="front_wheel_link">
    <visual>
        <geometry>
        <sphere radius="0.025"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>

        <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <sphere radius="0.025"/>
        </geometry>
        <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_link_front_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_wheel_link"/>
        <origin xyz="0.175 0.0 -0.125" rpy="0 0 0"/>
    </joint>

    <link name="front_wheel_link_x"/>

    <joint name="front_wheel_joint_x" type="continuous">
        <parent link="front_wheel_link"/>
        <child link="front_wheel_link_x"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
    </joint>

    <link name="front_wheel_link_y"/>

    <joint name="front_wheel_joint_y" type="continuous">
        <parent link="front_wheel_link_x"/>
        <child link="front_wheel_link_y"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <link name="front_wheel_link_z"/>

    <joint name="front_wheel_joint_z" type="continuous">
        <parent link="front_wheel_link_y"/>
        <child link="front_wheel_link_z"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- base_link_front_wheel_joint -->

    <!-- base_link_back_wheel_joint -->

    <link name="back_wheel_link">
    <visual>
        <geometry>
        <sphere radius="0.025"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>

        <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
        </material>
    </visual>

    <collision>
        <geometry>
        <sphere radius="0.025"/>
        </geometry>
        <origin xyz="0.0 0.0 0.05" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_link_back_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="back_wheel_link"/>
        <origin xyz="-0.175 0.0 -0.125" rpy="0 0 0"/>
    </joint>

    <link name="back_wheel_link_x"/>

    <joint name="back_wheel_joint_x" type="continuous">
        <parent link="back_wheel_link"/>
        <child link="back_wheel_link_x"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
    </joint>

    <link name="back_wheel_link_y"/>

    <joint name="back_wheel_joint_y" type="continuous">
        <parent link="back_wheel_link_x"/>
        <child link="back_wheel_link_y"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <link name="back_wheel_link_z"/>

    <joint name="back_wheel_joint_z" type="continuous">
        <parent link="back_wheel_link_y"/>
        <child link="back_wheel_link_z"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- base_link_back_wheel_joint -->



</robot>