<?xml version ="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Variables -->
    <xacro:property name="manipulator_link_width" value="0.04"/>
    <xacro:property name="manipulator_link_thickness" value="0.02"/>
    <xacro:property name="manipulator_joint_offset" value="0.01"/>

    <xacro:property name="q1_height" value="0.05"/>
    <xacro:property name="q1_limit_lower" value="${-3*pi / 4.0}"/>
    <xacro:property name="q1_limit_upper" value="${3*pi / 4.0}"/>
    <xacro:property name="q1_limit_effort" value="100"/>
    <xacro:property name="q1_limit_velocity" value="100.0"/>

    <xacro:property name="q2_length" value="0.132"/>
    <xacro:property name="q2_limit_lower" value="${-3*pi / 4.0}"/>
    <xacro:property name="q2_limit_upper" value="0.0"/>
    <xacro:property name="q2_limit_effort" value="100"/>
    <xacro:property name="q2_limit_velocity" value="100.0"/>

    <xacro:property name="q3_length" value="0.132"/>
    <xacro:property name="q3_limit_lower" value="${-3*pi / 4.0}"/>
    <xacro:property name="q3_limit_upper" value="${3*pi / 4.0}"/>
    <xacro:property name="q3_limit_effort" value="100"/>
    <xacro:property name="q3_limit_velocity" value="100.0"/>

    <!-- manipulator_base_link -->
    <xacro:cylinder link_name="manipulator_base_link" m="2.0" o_xyz="0 0 ${q1_height / 2.0}" 
    o_rpy="0 0 0" radius="0.06" length="${q1_height}" material_name="orange"/>
    <!-- manipulator_base_link -->

    <!-- q1 -->
    <xacro:sphere link_name="q1_link" m="0.75" o_xyz="0 0 0" o_rpy="0 0 0"
    radius="0.05" material_name="orange"/>

    <joint name="q1" type="revolute">
        <parent link="manipulator_base_link"/>
        <child link="q1_link"/>
        <origin xyz="0 0 ${q1_height + manipulator_link_width / 2.0}" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="${q1_limit_lower}" upper="${q1_limit_upper}" 
        effort="${q1_limit_effort}" velocity="${q1_limit_velocity}"/>
    </joint>
    <!-- q1 -->

    <!-- q2 -->
    <xacro:box_link link_name="q2_link" m="0.5" o_xyz="${q2_length / 2.0} 0 0" 
    o_rpy="0 0 0" length="${q2_length + manipulator_joint_offset}" width="${manipulator_link_width}"
    height="${manipulator_link_thickness}" material_name="orange"/>

    <joint name="q2" type="revolute">
        <parent link="q1_link"/>
        <child link="q2_link"/>
        <origin xyz="0 0 0" rpy="${-pi / 2.0} 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="${q2_limit_lower}" upper="${q2_limit_upper}" 
        effort="${q2_limit_effort}" velocity="${q2_limit_velocity}"/>
    </joint>
    <!-- q2 -->

    <!-- q3 -->
    <xacro:box_link link_name="q3_link" m="0.5" o_xyz="${q3_length / 2.0} 0 0" 
    o_rpy="0 0 0" length="${q3_length + manipulator_joint_offset}" width="${manipulator_link_width}" 
    height="${manipulator_link_thickness}" material_name="orange"/>

    <joint name="q3" type="revolute">
        <parent link="q2_link"/>
        <child link="q3_link"/>
        <origin xyz="${q2_length - manipulator_joint_offset} 0 ${manipulator_link_thickness}" 
        rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="${q3_limit_lower}" upper="${q3_limit_upper}" 
        effort="${q3_limit_effort}" velocity="${q3_limit_velocity}"/>
    </joint>
    <!-- q3 -->


    
</robot>