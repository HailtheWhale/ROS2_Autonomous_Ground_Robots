<?xml version ="1.0"?>

<robot name="agv_mini_manipulator" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Variables -->
    <xacro:property name="base_length" value="0.5"/>
    <xacro:property name="base_width" value="0.4"/>
    <xacro:property name="base_height" value="0.2"/>

    <xacro:property name="wheel_offset" value="0.075"/>
    <xacro:property name="wheel_thickness" value="0.05"/>
    <xacro:property name="wheel_radius" value="0.1"/>

    <xacro:property name="lidar_height" value="0.03"/>
    <xacro:property name="lidar_radius" value="0.03"/>

    <!-- Materials -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
    </material>

    <!-- Macro definitions -->
    <xacro:macro name="lidar" params="prefix">
        <link name="${prefix}_lidar_link">
            <visual>
                <geometry>
                    <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
                </geometry>
                <origin xyz="0 0 ${lidar_height / 2.0}" rpy="0 0 0"/>
                <material name="black"/>
            </visual>

            <collision>
                <geometry>
                    <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
                </geometry>
                <origin xyz="0 0 ${lidar_height / 2.0}" rpy="0 0 0"/>
            </collision>

            <inertial>
                <mass value="5.0"/>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:macro name="wheel" params="prefix">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" 
                    length="${wheel_thickness}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="gray"/>
            </visual>

            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" 
                    length="${wheel_thickness}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>

            <inertial>
                <mass value="5.0"/>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:macro name="castor_wheel" params="prefix">
        <link name="${prefix}_castor_wheel_link">
            <visual>
                <geometry>
                <sphere radius="${wheel_offset/2.0}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="gray"/>
            </visual>

            <collision>
                <geometry>
                <sphere radius="${wheel_offset/2.0}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>

            <inertial>
                <mass value="5.0"/>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:macro name="three_axis_joint" params="prefix parent_link">
        <link name="${prefix}_link_x"/>
        <joint name="${prefix}_joint_x" type="continuous">
            <parent link="${parent_link}"/>
            <child link="${prefix}_link_x"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <axis xyz="1 0 0"/>
        </joint>

        <link name="${prefix}_link_y"/>
        <joint name="${prefix}_joint_y" type="continuous">
            <parent link="${prefix}_link_x"/>
            <child link="${prefix}_link_y"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
        </joint>

        <link name="${prefix}_link_z"/>
        <joint name="${prefix}_joint_z" type="continuous">
            <parent link="${prefix}_link_y"/>
            <child link="${prefix}_link_z"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>
    </xacro:macro>

    <!-- base_footprint_base_link_joint -->
    <link name="base_footprint"/>

    <link name="base_link">
    <visual>
        <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="blue"/>
    </visual>

    <collision>
        <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>

    <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    </link>

    <joint name="base_footprint_base_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${base_height / 2.0 + wheel_offset}" rpy="0 0 0"/>
    </joint>
    <!-- base_footprint_base_link_joint -->

    <!-- base_link_lidar_front_joint -->
    <xacro:lidar prefix="front"/>
    <joint name="base_link_lidar_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_lidar_link"/>
        <origin xyz="${base_length / 2.0 - 0.05} 0.0 ${base_height / 2.0}" rpy="0 0 0"/>
    </joint>
    <!-- base_link_lidar_front_joint -->

    <!-- base_link_lidar_back_joint -->
    <xacro:lidar prefix="back"/>
    <joint name="base_link_lidar_back_joint" type="fixed">
        <parent link="base_link"/>
        <child link="back_lidar_link"/>
        <origin xyz="${-1.0*(base_length / 2.0 - 0.05)} 0.0 ${base_height / 2.0}" 
        rpy="0 0 ${pi / 2.0}"/>
    </joint>
    <!-- base_link_lidar_back_joint -->

    <!-- base_link_right_wheel_joint -->
    <xacro:wheel prefix="right"/>
    <joint name="base_link_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0.0 ${base_width / 2.0 + wheel_thickness / 2.0} ${-1.0 * (base_height / 2.0 - wheel_radius + wheel_offset)}"
        rpy="${-pi / 2.0} 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
    <!-- base_link_right_wheel_joint -->

    <!-- base_link_left_wheel_joint -->
    <xacro:wheel prefix="left"/>
    <joint name="base_link_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0.0 ${-1.0*(base_width / 2.0 + wheel_thickness / 2.0)} ${-1.0 * (base_height / 2.0 - wheel_radius + wheel_offset)}" 
        rpy="${pi / 2.0} 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
    <!-- base_link_left_wheel_joint -->

    <!-- base_link_front_wheel_joint -->
    <xacro:castor_wheel prefix="front"/>
    <joint name="base_link_front_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_castor_wheel_link"/>
        <origin xyz="${base_length / 2.0 - 0.075} 0.0 ${-1.0*(base_height / 2.0 + wheel_offset / 2.0)}" 
        rpy="0 0 0"/>
    </joint>
    <xacro:three_axis_joint prefix="front_castor_wheel" parent_link="front_castor_wheel_link"/>
    <!-- base_link_front_wheel_joint -->

    <!-- base_link_back_wheel_joint -->
    <xacro:castor_wheel prefix="back"/>
    <joint name="base_link_back_wheel_joint" type="fixed">
        <parent link="base_link"/>
        <child link="back_castor_wheel_link"/>
        <origin xyz="${-1.0*(base_length / 2.0 - 0.075)} 0.0 ${-1.0*(base_height / 2.0 + wheel_offset / 2.0)}" 
        rpy="0 0 0"/>
    </joint>
    <xacro:three_axis_joint prefix="back_castor_wheel" parent_link="back_castor_wheel_link"/>
    <!-- base_link_back_wheel_joint -->

</robot>